{
  "name": "patrolnet",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\" \"npm run start:mobile\"",
    "start:server": "cd server && node server.js",
    "start:client": "cd client && npm start",
    "start:mobile": "cd mobile && npm run start"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
